# Copy to server/.env and fill in real values. .env is gitignored.

# postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/secondhand_marketplace

# Optional. `npm test` otherwise derives this by appending _test to the database
# name above, creating it and migrating it on first run. The suite TRUNCATEs
# every table, and refuses to run against a database whose name does not end
# in "_test".
# TEST_DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/secondhand_marketplace_test

# Used to sign JWTs from Slice 2 onward. Any long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-string

PORT=4000
# Comma-separated. Vite falls back to 5174+ if 5173 is taken.
#
# The FIRST entry is also the origin used to build password-reset links, since a
# link in an email has to name exactly one host. Put the canonical one first.
CLIENT_ORIGIN=http://localhost:5173,http://localhost:5174

# Cloudinary — where listing photos and avatars live. Find these under
# Settings > API Keys in the Cloudinary console.
#
# The browser uploads directly to Cloudinary, so it needs the cloud name and the
# API key. It gets both from GET /api/uploads/signature, NOT from a VITE_ env
# var — that keeps one source of truth and one place to rotate.
#
# CLOUDINARY_API_SECRET must never reach the browser. It only ever signs upload
# parameters on this server. If it leaks, rotate it in the console immediately;
# anyone holding it can upload to and delete from your account.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=000000000000000
CLOUDINARY_API_SECRET=replace-me

# ─────────────────────────────────────────────────────────────────────────────
# Production settings. All optional; the defaults suit local development.
# ─────────────────────────────────────────────────────────────────────────────

# Set NODE_ENV=production in a real deployment. It disables dev-only behaviour
# (e.g. printing password-reset links to the console) and turns on the no-SMTP
# warning.
# NODE_ENV=production

# Database TLS. Unset means no TLS (fine for a local Postgres). For a REMOTE
# database this MUST be set, or credentials cross the network in plaintext:
#   require    — encrypt and verify the server certificate (correct default)
#   no-verify  — encrypt but skip verification (for providers with self-signed
#                or intermediate certs that fail strict checks)
# DATABASE_SSL=require

# Max connections this instance opens to Postgres. Keep the sum across all
# instances under the server's max_connections (default 100).
# DB_POOL_MAX=10

# How many reverse-proxy hops sit in front of the app (Nginx, a cloud LB, …).
# Required in production so rate limiting sees the real client IP from
# X-Forwarded-For rather than the proxy's. Usually 1.
# TRUST_PROXY=1

# SMTP, for actually delivering password-reset emails. Works with any provider
# that speaks SMTP (SES, Postmark, Resend, Mailgun, Gmail, …). With SMTP_HOST
# unset, reset emails are logged to the console in dev and NOT sent in prod.
#   SMTP_SECURE=true for port 465 (implicit TLS); false for 587 (STARTTLS).
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password
# MAIL_FROM="Secondhand <no-reply@yourdomain.com>"
